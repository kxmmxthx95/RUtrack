rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true;
    }

    // users/{uid} — profile owned by the authenticated user.
    // is_admin can never be set or changed by the user themself.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.get('is_admin', false) == false;
      allow update: if isOwner(userId)
        && request.resource.data.get('is_admin', false) == resource.data.get('is_admin', false);
      allow delete: if false;
    }

    // courses/{courseId} — each document belongs to one user via userId.
    match /courses/{courseId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      // milestones subcollection — ownership follows the parent course.
      match /milestones/{milestoneId} {
        allow read, write: if isSignedIn()
          && get(/databases/$(database)/documents/courses/$(courseId)).data.userId == request.auth.uid;
      }
    }

    // study_events/{eventId} — time-blocking entries per user.
    match /study_events/{eventId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // master_courses — global catalog: readable by any signed-in user,
    // writable only by admins.
    match /master_courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
