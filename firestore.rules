rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true;
    }

    // users/{uid} — profile owned by the authenticated user.
    // is_admin can never be set or changed by the user themself.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.get('is_admin', false) == false;
      allow update: if isOwner(userId)
        && request.resource.data.get('is_admin', false) == resource.data.get('is_admin', false);
      allow delete: if false;

      // courses/{courseId} — owned by the parent user via path, not a field.
      match /courses/{courseId} {
        allow read, write: if isOwner(userId);

        // milestones subcollection — ownership follows the parent course.
        match /milestones/{milestoneId} {
          allow read, write: if isOwner(userId);
        }
      }

      // study_events/{eventId} — time-blocking entries, owned via path.
      match /study_events/{eventId} {
        allow read, write: if isOwner(userId);
      }
    }

    // master_courses — global catalog: readable by any signed-in user,
    // writable only by admins.
    match /master_courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // curricula/{campus}/years/{year}/faculties/{faculty}/majors/{major}/courses/{courseId}
    // — courses attached to a campus/academic_year/faculty/major node in the
    // curriculum tree: readable by any signed-in user, writable only by admins.
    match /curricula/{campus}/years/{year}/faculties/{faculty}/majors/{major}/courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
